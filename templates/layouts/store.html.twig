{% extends 'base.html.twig' %}

{% block body_class %}
    {% set routeName = app.request ? (app.request.attributes.get('_route') ?? '') : '' %}
    {% set isGalleryRoute = routeName starts with 'store_gallery' %}
    {% set isMerchRoute = routeName starts with 'store_shop' or routeName starts with 'store_cart' %}
    {% set isContactRoute = routeName matches '/contact/' %}
    {% set isHomeRoute = routeName == 'store_home' %}
    theme-store{% if not isGalleryRoute and not isMerchRoute and not isContactRoute %} theme-store-section-slots{% else %} theme-store-no-section-slots{% endif %}{% if not isHomeRoute and not isGalleryRoute and not isMerchRoute and not isContactRoute %} theme-store-masked-auto{% else %} theme-store-no-masks{% endif %}
{% endblock %}

{% block body %}
    {% set settings = site_settings() %}
    {% set headerLogo = settings.headerLogo ? site_asset(settings.headerLogo, 'site') : asset('uploads/legacy/Logo.png') %}
    {% set sectionBackgroundPrimary = settings.sectionBackgroundPrimary ? site_asset(settings.sectionBackgroundPrimary, 'site') : asset('uploads/optimized/legacy/gal14.jpg') %}
    {% set sectionBackgroundSecondary = settings.sectionBackgroundSecondary ? site_asset(settings.sectionBackgroundSecondary, 'site') : asset('uploads/optimized/legacy/gal16.jpg') %}
    {% set sectionBackgroundTertiary = settings.sectionBackgroundTertiary ? site_asset(settings.sectionBackgroundTertiary, 'site') : asset('uploads/optimized/legacy/gal18.jpg') %}
    {% set footerStreamLinks = [
        { key: 'soundcloud', label: 'SoundCloud', url: settings.soundcloudUrl ?: 'https://soundcloud.com/soundofmemoriesmusic' },
        { key: 'spotify', label: 'Spotify', url: settings.spotifyUrl ?: 'https://open.spotify.com/album/2yemZEPhsqWdvWnKJh7rzd' },
        { key: 'apple', label: 'Apple Music', url: settings.appleMusicUrl ?: 'https://music.apple.com/fr/search?term=Sound%20Of%20Memories' },
        { key: 'youtube', label: 'YouTube Music', url: settings.youtubeMusicUrl ?: 'https://music.youtube.com/search?q=Sound%20Of%20Memories' }
    ] %}
    <div class="site-shell" style="--som-logo-url: url('{{ headerLogo }}'); --site-section-bg-primary: url('{{ sectionBackgroundPrimary }}'); --site-section-bg-secondary: url('{{ sectionBackgroundSecondary }}'); --site-section-bg-tertiary: url('{{ sectionBackgroundTertiary }}');">
        <header class="site-header">
            <div class="container header-row">
                <a class="brand brand-mobile" href="{{ path('store_home') }}">
                    <img src="{{ headerLogo }}" alt="{{ settings.siteName }}" width="484" height="92" decoding="async">
                </a>

                <button class="nav-toggle" type="button" data-nav-toggle aria-expanded="false" aria-controls="site-navigation" aria-label="Ouvrir le menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>

                <nav class="main-nav" id="site-navigation" data-main-nav>
                    <div class="menu-shell">
                        <div class="menu-edge-spacer" aria-hidden="true"></div>

                        <div class="menu-side menu-side-left">
                            <a class="menu-link" href="{{ path('store_concerts') }}">Concert</a>
                            <a class="menu-link" href="{{ path('store_gallery') }}">Gallery</a>
                        </div>

                        <a class="brand brand-desktop" href="{{ path('store_home') }}">
                            <img src="{{ headerLogo }}" alt="{{ settings.siteName }}" width="484" height="92" decoding="async">
                        </a>

                        <div class="menu-side menu-side-right">
                            <a class="menu-link" href="{{ path('store_about') }}">The Band</a>
                            <a class="menu-link" href="{{ path('store_shop_index') }}">Merch</a>
                        </div>

                        <div class="menu-edge-actions">
                            {% if is_granted('ROLE_USER') %}
                                <a class="nav-ghost nav-account" href="{{ path('app_account') }}">Mon compte</a>
                            {% else %}
                                <a class="nav-ghost nav-account" href="{{ path('app_login') }}">Mon compte</a>
                            {% endif %}
                            <a class="nav-ghost nav-cart" href="{{ path('store_cart') }}">Panier <span class="pill">{{ cart_count() }}</span></a>
                        </div>
                    </div>
                </nav>
            </div>
        </header>

        <main>
            {% for label, messages in app.flashes %}
                <div class="container flash-stack">
                    {% for message in messages %}
                        <div class="flash flash-{{ label }}">{{ message }}</div>
                    {% endfor %}
                </div>
            {% endfor %}

            {% block page %}{% endblock %}
        </main>

        <footer class="site-footer">
            <div class="container footer-bar">
                <div class="footer-socials">
                    <a class="footer-brand-mini" href="{{ path('store_home') }}" aria-label="Sound Of Memories">
                        <img src="{{ headerLogo }}" alt="{{ settings.siteName }}" width="484" height="92" loading="lazy" decoding="async">
                    </a>
                    <div class="footer-stream-links" aria-label="Plateformes musicales Sound Of Memories">
                        {% for link in footerStreamLinks %}
                            <a class="footer-stream-link is-{{ link.key }}" href="{{ link.url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ link.label }}">
                                {% if link.key == 'soundcloud' %}
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M5 16h1.5V9.5H5V16Zm2.5 0H9V8H7.5v8Zm2.5 0h1.5V7h-1.5v9Zm2.5 0H14V8.5h-1.5V16Zm2.35-1.1a3.6 3.6 0 0 0 0-7.2 4.7 4.7 0 0 0-4.45 3.2A2.6 2.6 0 0 0 10.6 16H17a2.1 2.1 0 0 0 .35-4.1Z" fill="currentColor"/>
                                    </svg>
                                {% elseif link.key == 'spotify' %}
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 2.2A9.8 9.8 0 1 0 21.8 12 9.8 9.8 0 0 0 12 2.2Zm4.5 14.2a.9.9 0 0 1-1.24.3 8.7 8.7 0 0 0-8.83-.52.9.9 0 1 1-.8-1.62 10.5 10.5 0 0 1 10.71.64.9.9 0 0 1 .16 1.2Zm1.76-2.67a1.12 1.12 0 0 1-1.53.37 10.7 10.7 0 0 0-10.87-.63 1.12 1.12 0 0 1-1-2 12.95 12.95 0 0 1 13.13.77 1.12 1.12 0 0 1 .27 1.49Zm.15-2.86a13.45 13.45 0 0 0-13.8-.74 1.35 1.35 0 1 1-1.25-2.4 16.15 16.15 0 0 1 16.59.88 1.35 1.35 0 1 1-1.54 2.26Z" fill="currentColor"/>
                                    </svg>
                                {% elseif link.key == 'apple' %}
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M15.7 4.8a2.9 2.9 0 0 1-2.2 1 3 3 0 0 1 .86-2A3.1 3.1 0 0 1 16.6 3a2.6 2.6 0 0 1-.9 1.8ZM18 12.8c0 2.5 1.7 3.4 1.7 3.5-.02.08-.27.9-.9 1.8-.54.78-1.1 1.56-2 1.58-.86.02-1.14-.5-2.12-.5-.99 0-1.29.48-2.11.52-.84.03-1.49-.85-2.03-1.63-1.1-1.58-1.94-4.44-.8-6.42a3.1 3.1 0 0 1 2.6-1.6c.82-.02 1.6.55 2.12.55.51 0 1.48-.68 2.5-.58.43.02 1.64.17 2.42 1.31-.06.04-1.45.84-1.45 2.47Z" fill="currentColor"/>
                                    </svg>
                                {% else %}
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 3a9 9 0 1 0 9 9 9 9 0 0 0-9-9Zm-1.3 12.9V8.1L16.8 12l-6.1 3.9Zm-6.1-3.2a7.4 7.4 0 0 1 14.8 0 7.4 7.4 0 0 1-14.8 0Z" fill="currentColor"/>
                                    </svg>
                                {% endif %}
                            </a>
                        {% endfor %}
                    </div>
                </div>
                <div class="footer-meta-links">
                    <a href="{{ path('store_legal') }}">Mentions légales</a>
                    <a href="{{ path('store_cgv') }}">CGV</a>
                    <a href="{{ path('store_privacy') }}">Confidentialité</a>
                </div>
            </div>
        </footer>
    </div>
{% endblock %}
