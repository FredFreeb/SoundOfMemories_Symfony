{% extends 'layouts/store.html.twig' %}

{% block title %}Commande confirmée | Sound Of Memories{% endblock %}
{% block meta_description %}Confirmation de commande Sound Of Memories et récapitulatif du paiement effectué.{% endblock %}
{% block meta_robots %}noindex,nofollow{% endblock %}

{% block page %}
    <section class="section section-bg-1">
        <div class="container centered-panel">
            <p class="eyebrow">Paiement confirmé</p>
            <h1>Merci pour ta commande</h1>
            <p>Commande {{ order }}. Le statut de paiement est actuellement <strong>{{ order.paymentStatusLabel }}</strong> et la préparation pourra commencer dès validation complète.</p>
            <div class="checkout-summary-list centered-summary-list">
                <div class="summary-line">
                    <span>Sous-total</span>
                    <strong>{{ order.formattedSubtotal }}</strong>
                </div>
                {% if order.discountCents > 0 %}
                    <div class="summary-line">
                        <span>{{ order.discountLabel }}</span>
                        <strong>-{{ order.formattedDiscount }}</strong>
                    </div>
                {% endif %}
                <div class="summary-line">
                    <span>Total facturé</span>
                    <strong>{{ order.formattedTotal }}</strong>
                </div>
            </div>
            <div class="hero-actions">
                <a class="button-primary" href="{{ path('store_shop_index') }}">Continuer les achats</a>
                <a class="button-secondary" href="{{ path('store_home') }}">Retour à l’accueil</a>
            </div>
        </div>
    </section>
{% endblock %}
