{% extends 'layouts/store.html.twig' %}

{% block title %}Commande | Sound Of Memories{% endblock %}
{% block meta_description %}Validation de commande Sound Of Memories avec livraison, résumé sécurisé et redirection Stripe.{% endblock %}
{% block meta_robots %}noindex,nofollow{% endblock %}

{% block page %}
    {% set checkoutEmail = form.customerEmail.vars.value ?: 'Email de suivi à renseigner' %}
    {% set checkoutPhone = form.customerPhone.vars.value ?: 'Téléphone à renseigner' %}

    <section class="section section-bg-none account-page-section checkout-page-section">
        <div class="container checkout-page-container">
            <div class="checkout-page-intro">
                <div class="checkout-page-intro-grid">
                    <div class="checkout-page-copy">
                        <p class="eyebrow">Commande</p>
                        <h1>Finaliser votre commande</h1>
                        <p class="checkout-page-lead">Renseignez votre adresse, choisissez la livraison, puis validez le paiement.</p>
                    </div>
                    <div class="checkout-stage-list" aria-label="Etapes de commande">
                        <span><strong>1</strong> Adresse</span>
                        <span><strong>2</strong> Livraison</span>
                        <span><strong>3</strong> Paiement</span>
                    </div>
                </div>
                <div class="checkout-status-line" aria-label="Statut du checkout">
                    <span>{{ app.user ? 'Compte fan reconnu' : 'Commande invité possible' }}</span>
                    <span>{{ boxtalConfigured ? 'Livraison calculée en direct' : 'Livraison provisoire' }}</span>
                    <span>Paiement sécurisé par Stripe</span>
                </div>
            </div>

            <div class="checkout-dashboard">
                <div class="checkout-main-column">
                    <article class="detail-panel checkout-form-panel">
                        <div class="section-heading section-heading-compact checkout-heading">
                            <div>
                                <h2>Informations de livraison</h2>
                                <p class="account-section-subtitle">Le total se met à jour selon le mode de livraison sélectionné.</p>
                            </div>
                            <div class="checkout-contact-line" aria-label="Repères de commande">
                                <span>{{ checkoutEmail }}</span>
                                <span>{{ checkoutPhone }}</span>
                            </div>
                        </div>

                        <div class="checkout-notice-stack">
                            {% if not stripeConfigured %}
                                <div class="checkout-notice is-warning">Le paiement ne pourra pas démarrer tant que Stripe n’aura pas été configuré dans l’environnement local.</div>
                            {% endif %}

                            {% if not boxtalConfigured %}
                                <div class="checkout-notice">Les frais de livraison affichés ici sont provisoires.</div>
                            {% endif %}
                        </div>

                        {{ form_start(form, {attr: {
                            class: 'account-profile-form checkout-form',
                            autocomplete: 'off',
                            'data-address-autocomplete-form': 'true',
                            'data-address-autocomplete-endpoint': address_autocomplete_endpoint
                        }}) }}
                            {{ form_errors(form) }}
                            <section class="account-form-section checkout-form-section">
                                <div class="account-form-section-header checkout-step-header">
                                    <span class="checkout-step-index">1</span>
                                    <div>
                                        <p class="eyebrow">Destinataire</p>
                                        <h3>Coordonnées</h3>
                                        <p>Nom, email et téléphone pour le suivi.</p>
                                    </div>
                                </div>
                                <div class="form-grid form-grid-double">
                                    {{ form_row(form.customerName) }}
                                    {{ form_row(form.customerEmail) }}
                                    {{ form_row(form.customerPhone) }}
                                </div>
                            </section>

                            <section class="account-form-section checkout-form-section">
                                <div class="account-form-section-header checkout-step-header">
                                    <span class="checkout-step-index">2</span>
                                    <div>
                                        <p class="eyebrow">Expédition</p>
                                        <h3>Adresse de livraison</h3>
                                        <p>Choisissez d’abord le pays, puis laissez-vous guider.</p>
                                    </div>
                                </div>
                                <div class="form-grid form-grid-double">
                                    {{ form_row(form.shippingCountryCode) }}
                                    {{ form_row(form.postalCode) }}
                                    {{ form_row(form.city) }}
                                    <div class="form-grid-full">
                                        {{ form_row(form.shippingAddress) }}
                                    </div>
                                    {{ form_row(form.shippingStreetNumber) }}
                                    <div class="form-grid-full">
                                        {{ form_row(form.note) }}
                                    </div>
                                    <div class="form-grid-full checkout-shipping-method-row">
                                        {{ form_row(form.shippingMethodCode) }}
                                    </div>
                                </div>
                            </section>

                            <section class="account-form-section checkout-form-section">
                                <div class="account-form-section-header checkout-step-header">
                                    <span class="checkout-step-index">3</span>
                                    <div>
                                        <p class="eyebrow">Validation</p>
                                        <h3>Accords obligatoires</h3>
                                        <p>Confirmation des conditions avant paiement.</p>
                                    </div>
                                </div>
                                <div class="form-grid">
                                    <div class="form-grid-full">
                                        {{ form_row(form.acceptCgv) }}
                                    </div>
                                    <div class="form-grid-full">
                                        {{ form_row(form.acceptPrivacy) }}
                                    </div>
                                </div>
                            </section>

                            {{ form_widget(form._token) }}

                            <div class="checkout-submit-row">
                                <button class="button-primary checkout-submit" type="submit">Continuer vers Stripe</button>
                                <p class="checkout-submit-note">Redirection sécurisée vers Stripe. Aucune donnée bancaire n’est stockée ici.</p>
                            </div>
                        {{ form_end(form, { render_rest: false }) }}
                    </article>
                </div>

                <aside class="checkout-side-column">
                    <article class="detail-panel checkout-summary-panel">
                        <p class="eyebrow">Résumé</p>
                        <h2>Votre commande</h2>
                        <p class="checkout-summary-intro">{{ items|length }} article{{ items|length > 1 ? 's' : '' }} avant paiement.</p>

                        <div class="checkout-summary-total-card">
                            <span>Total estimé</span>
                            <strong>{{ (previewTotalCents / 100)|number_format(2, ',', ' ') }} EUR</strong>
                        </div>

                        <div class="checkout-trust-list">
                            <span>Paiement Stripe sécurisé</span>
                            <span>Livraison suivie</span>
                            <span>Support Sound Of Memories</span>
                        </div>

                        <div class="checkout-summary-items">
                            {% for item in items %}
                                {% set mediaUrl = item.product.coverImage
                                    ? (item.product.coverImage starts with 'http' or item.product.coverImage starts with '/'
                                        ? item.product.coverImage
                                        : asset('uploads/products/' ~ item.product.coverImage))
                                    : null
                                %}
                                <article class="checkout-summary-item-card">
                                    <div class="checkout-summary-item-card__media">
                                        {% if mediaUrl %}
                                            <img src="{{ mediaUrl }}" alt="{{ item.displayName }}" width="120" height="120" loading="lazy" decoding="async">
                                        {% else %}
                                            <span>Visuel à venir</span>
                                        {% endif %}
                                    </div>
                                    <div class="checkout-summary-item-card__copy">
                                        <strong>{{ item.product.name }}</strong>
                                        {% if item.variant %}
                                            <span>{{ item.product.variantChoiceLabel }} : {{ item.variant.label }}</span>
                                        {% endif %}
                                        <span>Quantité : {{ item.quantity }}</span>
                                    </div>
                                    <strong class="checkout-summary-item-card__price">{{ (item.totalCents / 100)|number_format(2, ',', ' ') }} EUR</strong>
                                </article>
                            {% endfor %}
                        </div>

                        <div class="checkout-summary-list">
                            <div class="summary-line total">
                                <span>Sous-total produits</span>
                                <strong>{{ (totalCents / 100)|number_format(2, ',', ' ') }} EUR</strong>
                            </div>

                            {% if previewDiscountCents > 0 %}
                                <div class="summary-line">
                                    <span>Réduction bienvenue</span>
                                    <strong>-{{ (previewDiscountCents / 100)|number_format(2, ',', ' ') }} EUR</strong>
                                </div>
                            {% endif %}

                            <div class="summary-line">
                                <span>
                                    Livraison
                                    {% if previewShippingEstimated %}estimée{% endif %}
                                    {% if previewShippingLabel %}· {{ previewShippingLabel }}{% else %}· à choisir{% endif %}
                                </span>
                                <strong>
                                    {% if previewShippingLabel %}
                                        {{ (previewShippingCents / 100)|number_format(2, ',', ' ') }} EUR
                                    {% else %}
                                        --
                                    {% endif %}
                                </strong>
                            </div>

                            <div class="summary-line total">
                                <span>Total à régler</span>
                                <strong>{{ (previewTotalCents / 100)|number_format(2, ',', ' ') }} EUR</strong>
                            </div>
                        </div>
                    </article>
                </aside>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('scripts/form-enhancements.js') }}" defer></script>
{% endblock %}
