{% extends 'layouts/store.html.twig' %}

{% block body_class %}{{ parent() }} theme-store-home{% endblock %}

{% block title %}Accueil | Sound Of Memories{% endblock %}
{% block meta_description %}Sound Of Memories — groupe de métal mélodique. Merch officiel, dates de concert, galerie photos et vidéos, albums en streaming.{% endblock %}
{% block stylesheets %}
    {% set siteSettings = site_settings() %}
    {% set heroBackgroundPreload = siteSettings.homeHeroBackground ? site_asset(siteSettings.homeHeroBackground, 'site') : asset('uploads/legacy/htmlwallpaper.jpg') %}
    {% set heroVisualPreload = siteSettings.homeHeroVisual ? site_asset(siteSettings.homeHeroVisual, 'site') : asset('uploads/optimized/legacy/SofM-cover.jpg') %}
    {% set heroLogoPreload = siteSettings.headerLogo ? site_asset(siteSettings.headerLogo, 'site') : asset('uploads/legacy/Logo.png') %}
    {% set heroTrailerPreload = asset('uploads/site/hero/background/Sound%20Of%20Memories%20-%20The%20Living%20Circles%20Tour%20%5BTRAILER%5D.mp4') %}
    <link rel="preload" as="image" href="{{ heroBackgroundPreload }}">
    <link rel="preload" as="image" href="{{ heroVisualPreload }}">
    <link rel="preload" as="image" href="{{ heroLogoPreload }}">
    <link rel="preload" as="video" href="{{ heroTrailerPreload }}" type="video/mp4">
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/product-effects.css') }}">
{% endblock %}

{% block page %}
    {% set heroBackground = siteSettings.homeHeroBackground ? site_asset(siteSettings.homeHeroBackground, 'site') : asset('uploads/legacy/htmlwallpaper.jpg') %}
    {% set heroVisual = siteSettings.homeHeroVisual ? site_asset(siteSettings.homeHeroVisual, 'site') : asset('uploads/optimized/legacy/SofM-cover.jpg') %}
    {% set heroLogo = siteSettings.headerLogo ? site_asset(siteSettings.headerLogo, 'site') : asset('uploads/legacy/Logo.png') %}
    {% set heroTrailer = asset('uploads/site/hero/background/Sound%20Of%20Memories%20-%20The%20Living%20Circles%20Tour%20%5BTRAILER%5D.mp4') %}
    {% set heroFacts = [
        { value: '2010', label: 'Début du groupe' },
        { value: '3 releases', label: '2013 · 2015 · 2020' },
        { value: '50+', label: 'concerts et scènes défendues' }
    ] %}
    {% set spotlight = monthlyOfferProduct ?: products|first %}
    {% set liveBackgrounds = [
        asset('uploads/optimized/legacy/gal13.jpg'),
        asset('uploads/optimized/legacy/gal14.jpg'),
        asset('uploads/optimized/legacy/gal15.jpg'),
        asset('uploads/optimized/legacy/gal16.jpg'),
        asset('uploads/optimized/legacy/gal18.jpg')
    ] %}
    {% set spotlightImage = spotlight and spotlight.offerBannerImage
        ? (spotlight.offerBannerImage starts with 'http' or spotlight.offerBannerImage starts with '/'
            ? spotlight.offerBannerImage
            : asset('uploads/products/' ~ spotlight.offerBannerImage))
        : (spotlight and spotlight.coverImage
            ? (spotlight.coverImage starts with 'http' or spotlight.coverImage starts with '/'
                ? spotlight.coverImage
                : asset('uploads/products/' ~ spotlight.coverImage))
            : random(liveBackgrounds))
    %}

    <section
        class="hero-section home-hero-cinematic"
        data-home-hero
        style="--hero-poster: url('{{ heroBackground }}'); --hero-cover: url('{{ heroVisual }}');"
    >
        <div class="home-hero-cinematic__media" aria-hidden="true">
            <video class="home-hero-cinematic__video" data-home-hero-video autoplay muted loop playsinline preload="auto" poster="{{ heroBackground }}">
                <source src="{{ heroTrailer }}" type="video/mp4">
            </video>
        </div>
        <div class="home-hero-cinematic__veil" aria-hidden="true"></div>
        <div class="home-hero-cinematic__center-mark" aria-hidden="true" style="--hero-logo-url: url('{{ heroLogo }}');">
            <span class="home-hero-cinematic__center-glow"></span>
            <span class="home-hero-cinematic__logo-ghost home-hero-cinematic__logo-ghost--warm"></span>
            <span class="home-hero-cinematic__logo-ghost home-hero-cinematic__logo-ghost--cool"></span>
            <img class="home-hero-cinematic__center-logo" src="{{ heroLogo }}" alt="" width="484" height="92" decoding="async">
        </div>
        <div class="hero-mist" aria-hidden="true"></div>
        <div class="hero-edge-flare hero-edge-flare--left" aria-hidden="true"></div>
        <div class="hero-edge-flare hero-edge-flare--right" aria-hidden="true"></div>
        <div class="container home-hero-cinematic__grid">
            <div class="hero-copy home-hero-cinematic__copy">
                <p class="eyebrow">Living Circles Tour</p>
                <p class="home-hero-cinematic__kicker">Trailer officiel en fond de scène</p>
                <h1>{{ siteSettings.homeHeroTitle ?: 'The Sound never dies. The stage remembers.' }}</h1>
                <p class="hero-text home-hero-cinematic__lead">{{ siteSettings.homeHeroText ?: 'Un hero pensé comme une affiche live en mouvement. La vidéo locale tourne en plein écran, la scène respire, et l’univers Sound Of Memories s’impose dès la première seconde.' }}</p>
                <div class="button-row home-hero-cinematic__actions">
                    <a class="button-primary button-primary--glow" href="{{ path('store_shop_index') }}">
                        <span>Voir le merch</span>
                    </a>
                    <a class="button-secondary" href="{{ path('store_concerts') }}">Voir les concerts</a>
                    <a class="text-link" href="{{ path('store_gallery') }}">Entrer dans la gallery</a>
                </div>
                <div class="home-hero-cinematic__facts">
                    {% for fact in heroFacts %}
                        <article class="home-hero-cinematic__fact">
                            <strong>{{ fact.value }}</strong>
                            <span>{{ fact.label }}</span>
                        </article>
                    {% endfor %}
                </div>
            </div>
            <div class="hero-visual-shell home-hero-cinematic__aside">
                <div class="hero-glow"></div>
                <div class="home-hero-cinematic__panel home-hero-cinematic__panel--poster">
                    <div class="home-hero-cinematic__poster-frame">
                        <img src="{{ heroVisual }}" alt="Visuel Sound Of Memories" width="1414" height="1414" fetchpriority="high" decoding="async">
                        <span class="home-hero-cinematic__poster-tag">Trailer loop</span>
                    </div>
                </div>
                <div class="hero-rings" aria-hidden="true">
                    <div class="hero-ring hero-ring--1"></div>
                    <div class="hero-ring hero-ring--2"></div>
                    <div class="hero-ring hero-ring--3"></div>
                </div>
                <div class="home-hero-cinematic__panel home-hero-cinematic__panel--meta">
                    <p class="card-kicker">Now loading</p>
                    <h2>Living Circles Tour</h2>
                    <p>Le trailer local tourne en fond pour donner une vraie sensation de scène, de souffle et de tension dès l’arrivée sur la home.</p>
                    <div class="home-hero-cinematic__meta-grid">
                        <div>
                            <strong>Source</strong>
                            <span>MP4 local en autoplay muet</span>
                        </div>
                        <div>
                            <strong>Vibe</strong>
                            <span>cinématique, live, organique</span>
                        </div>
                        <div>
                            <strong>Focus</strong>
                            <span>concerts, gallery, merch</span>
                        </div>
                    </div>
                    <a class="text-link" href="{{ path('store_gallery') }}">Voir toutes les vidéos</a>
                </div>
            </div>
        </div>
        <button class="scroll-indicator" type="button" data-scroll-indicator aria-label="Faire défiler vers le contenu">
            {% if siteSettings.headerLogo %}
                <img class="scroll-indicator__logo" src="{{ site_asset(siteSettings.headerLogo, 'site') }}" alt="Sound Of Memories" width="484" height="92" loading="lazy" decoding="async">
            {% else %}
                <span class="scroll-indicator__monogram">SOM</span>
            {% endif %}
            <svg class="scroll-indicator__chevron" width="18" height="22" viewBox="0 0 18 22" aria-hidden="true" focusable="false">
                <path d="M2 7l7 8 7-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
    </section>

    {% if spotlight %}
        {% include 'components/_masked_image_section.html.twig' with {
            eyebrow: spotlight.offerBannerEyebrow ?: 'A la une',
            title: spotlight.offerBannerTitle ?: spotlight.name,
            text: spotlight.offerBannerText ?: spotlight.shortDescription,
            meta_primary: spotlight.formattedPrice,
            meta_secondary: spotlight.stock ~ ' en stock',
            button_label: 'Découvrir le produit',
            button_url: path('store_shop_show', {slug: spotlight.slug}),
            image_url: spotlightImage,
            image_alt: spotlight.name,
            class_name: 'masked-image-section--featured'
        } only %}

    {% endif %}

    <section class="section section-bg-1 som-hero som-hero--section">
        <div class="som-hero__bg" aria-hidden="true"></div>
        <div class="som-hero__content">
            <div class="container section-head">
                <div>
                    <p class="eyebrow">Official Merch</p>
                    <h2>Porte les couleurs du groupe.</h2>
                </div>
                <a class="text-link" href="{{ path('store_shop_index') }}">Tout le catalogue</a>
            </div>
            <div class="container card-grid">
                {% for product in products %}
                    <article class="product-card">
                        <a href="{{ path('store_shop_show', {slug: product.slug}) }}" aria-label="{{ product.name }}">
                            {% include 'store/components/_product_media.html.twig' with {
                                product: product,
                                media_classes: 'product-media'
                            } only %}
                        </a>
                        <div class="product-card-copy">
                            <p class="card-kicker">{{ product.category ? product.category.name : 'Merch' }}</p>
                            <h3><a href="{{ path('store_shop_show', {slug: product.slug}) }}" aria-label="{{ product.name }}">{{ product.name }}</a></h3>
                            <p>{{ product.catalogExcerpt ?: product.shortDescription }}</p>
                            <div class="product-card-footer">
                                <strong>{{ product.formattedPrice }}</strong>
                                <a class="text-link" href="{{ path('store_shop_show', {slug: product.slug}) }}" aria-label="{{ product.name }}">Voir</a>
                            </div>
                        </div>
                    </article>
                {% else %}
                    <article class="empty-card">
                        <h3>Aucun produit publié</h3>
                        <p>Les pièces de merchandising apparaîtront ici dès qu’elles seront ajoutées dans l’admin.</p>
                    </article>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="section section-bg-2 som-hero som-hero--section">
        <div class="som-hero__bg" aria-hidden="true"></div>
        <div class="som-hero__content">
            <div class="container section-head">
                <div>
                    <p class="eyebrow">Live Dates</p>
                    <h2>On stage. Les prochains rendez-vous.</h2>
                </div>
                <a class="text-link" href="{{ path('store_concerts') }}">Toutes les dates</a>
            </div>
            <div class="concert-list">
                {% for concert in upcomingConcerts %}
                    <article class="concert-card{% if concert.isHighlighted %} is-highlighted{% endif %}">
                        <div class="concert-date">
                            <strong>{{ concert.concertAt|date('d') }}</strong>
                            <span>{{ concert.concertAt|date('M Y')|upper }}</span>
                        </div>
                        <div class="concert-copy">
                            <p class="card-kicker">{{ concert.venue }}</p>
                            <h3>{{ concert.title }}</h3>
                            <p>{{ concert.locationLabel }} · {{ concert.concertAt|date('H:i') }}</p>
                            {% if concert.details %}
                                <p>{{ concert.details }}</p>
                            {% endif %}
                        </div>
                        <div class="concert-side">
                            <span class="status-badge status-{{ concert.status }}">{{ concert.statusLabel }}</span>
                            {% if concert.ticketUrl %}
                                <a class="button-secondary" href="{{ concert.ticketUrl }}" target="_blank" rel="noopener">Billetterie</a>
                            {% endif %}
                        </div>
                    </article>
                {% else %}
                    <article class="empty-card">
                        <h3>Aucune date publiée</h3>
                        <p>Les prochaines dates seront annoncées ici dès qu'elles seront confirmées.</p>
                    </article>
                {% endfor %}
            </div>
        </div>
    </section>

    {% if editorial.press is defined and editorial.press is not null %}
        {% include 'components/editorial/_module_press_clippings.html.twig' with {
            module: editorial.press,
            entries: pressEntries,
            canManage: is_granted('ROLE_ADMIN'),
            manageUrl: path('admin_dashboard_avis_presse_index'),
            manageLabel: 'Gérer la presse'
        } only %}
    {% endif %}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('scripts/home.js') }}" defer></script>
{% endblock %}
