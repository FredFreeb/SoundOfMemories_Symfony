{% extends 'layouts/store.html.twig' %}

{% block title %}{{ product.name }} | Sound Of Memories{% endblock %}
{% block meta_description %}{{ product.shortDescription ?: product.description ?: 'Produit merchandising Sound Of Memories.' }}{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/product-effects.css') }}">
{% endblock %}

{% block page %}
    {% set mediaGallery = [] %}
    {% if product.coverImage %}
        {% set coverUrl = product.coverImage starts with 'http' or product.coverImage starts with '/' ? product.coverImage : asset('uploads/products/' ~ product.coverImage) %}
        {% set mediaGallery = mediaGallery|merge([{ url: coverUrl, alt: product.name }]) %}
    {% endif %}
    {% for image in product.galleryImages %}
        {% set galleryUrl = image.imagePath starts with 'http' or image.imagePath starts with '/' ? image.imagePath : asset('uploads/product-gallery/' ~ image.imagePath) %}
        {% set mediaGallery = mediaGallery|merge([{ url: galleryUrl, alt: image.altText ?: product.name }]) %}
    {% endfor %}
    {% set mainMedia = mediaGallery|first %}
    {% set selectedVariant = defaultVariant %}
    {% set currentPriceCents = selectedVariant ? selectedVariant.priceCents : product.startingPriceCents %}
    {% set currentCompareAtCents = product.promotionActive and selectedVariant and selectedVariant.compareAtPriceCents ? selectedVariant.compareAtPriceCents : product.displayCompareAtPriceCents %}
    {% set currentSavingsCents = currentCompareAtCents and currentCompareAtCents > currentPriceCents ? currentCompareAtCents - currentPriceCents : 0 %}

    <section class="section section-bg-1 merch-product-section">
        <div class="container merch-product-shell">
            <div class="merch-product-gallery" data-product-gallery>
                <div class="merch-product-gallery__main">
                    {% if mainMedia %}
                        <img
                            src="{{ mainMedia.url }}"
                            alt="{{ mainMedia.alt }}"
                            class="merch-product-gallery__image"
                            data-main-product-image
                            width="1200"
                            height="1200"
                            loading="eager"
                            decoding="async"
                        >
                    {% else %}
                        <div class="merch-product-gallery__fallback">Visuel à venir</div>
                    {% endif %}
                </div>

                {% if mediaGallery|length > 1 %}
                    <div class="merch-product-gallery__thumbs">
                        {% for media in mediaGallery %}
                            <button
                                type="button"
                                class="merch-product-gallery__thumb{% if loop.first %} is-active{% endif %}"
                                data-product-thumb
                                data-image-url="{{ media.url }}"
                                data-image-alt="{{ media.alt }}"
                                aria-label="Voir l’image {{ loop.index }} du produit"
                            >
                                <img src="{{ media.url }}" alt="" width="180" height="180" loading="lazy" decoding="async">
                            </button>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="merch-product-buybox" data-product-options data-promotion-active="{{ product.promotionActive ? '1' : '0' }}">
                <div class="merch-product-header-meta">
                    <p class="eyebrow">{{ product.category ? product.category.name : 'Merchandising' }}</p>
                    {% if product.merchBadge %}
                        <span class="merch-badge merch-badge--{{ product.merchBadgeTone }}">{{ product.merchBadge }}</span>
                    {% endif %}
                    {% if product.isMonthlyOffer %}
                        <span class="merch-badge merch-badge--ember">Offre du mois</span>
                    {% endif %}
                    {% if product.hasPromotionPricing and product.promotionUpcoming %}
                        <span class="merch-badge merch-badge--sand">Promo dès le {{ product.promotionStartsAt|date('d/m') }}</span>
                    {% elseif product.displayCompareAtPriceCents %}
                        <span class="merch-badge merch-badge--ember">Prix promo actif</span>
                    {% endif %}
                </div>
                <h1>{{ product.name }}</h1>
                <p class="merch-product-lead">{{ product.shortDescription ?: product.catalogExcerpt }}</p>

                <div class="merch-product-signals">
                    <article class="merch-product-signal">
                        <strong>Collection</strong>
                        <span>{{ product.category ? product.category.name : 'Merch' }}</span>
                    </article>
                    <article class="merch-product-signal">
                        <strong>Options</strong>
                        <span>{{ variants|length > 0 ? variants|length ~ ' choix' : 'Edition unique' }}</span>
                    </article>
                    <article class="merch-product-signal">
                        <strong>Disponibilité</strong>
                        <span>{{ product.displayStock > 0 ? product.displayStock ~ ' en stock' : 'Rupture' }}</span>
                    </article>
                </div>

                {% if product.sellingPoints is not empty %}
                    <div class="merch-points merch-points--product">
                        {% for point in product.sellingPoints %}
                            <span>{{ point }}</span>
                        {% endfor %}
                    </div>
                {% endif %}

                <div class="merch-product-pricing">
                    {% if selectedVariant and selectedVariant.formattedCompareAtPrice %}
                        <span class="merch-product-pricing__compare js-variant-compare">{{ selectedVariant.formattedCompareAtPrice }}</span>
                    {% elseif product.formattedDisplayCompareAtPrice %}
                        <span class="merch-product-pricing__compare js-variant-compare">{{ product.formattedDisplayCompareAtPrice }}</span>
                    {% else %}
                        <span class="merch-product-pricing__compare js-variant-compare is-hidden"></span>
                    {% endif %}

                    <strong class="merch-product-pricing__main js-variant-price">{{ selectedVariant ? selectedVariant.formattedPrice : product.formattedStartingPrice }}</strong>
                    <span class="merch-product-pricing__stock js-variant-stock">
                        {% if selectedVariant %}
                            {{ selectedVariant.stock }} disponible{{ selectedVariant.stock > 1 ? 's' : '' }}
                        {% else %}
                            {{ product.displayStock }} disponible{{ product.displayStock > 1 ? 's' : '' }}
                        {% endif %}
                    </span>
                    <span class="merch-product-pricing__saving js-variant-saving{% if currentSavingsCents <= 0 %} is-hidden{% endif %}">
                        {% if currentSavingsCents > 0 %}
                            Vous économisez {{ (currentSavingsCents / 100)|number_format(2, ',', ' ') }} EUR
                        {% endif %}
                    </span>
                </div>

                {% if product.hasPromotionPricing and product.promotionUpcoming %}
                    <p class="merch-product-promo-state">La réduction s’activera automatiquement{% if product.promotionStartsAt %} le {{ product.promotionStartsAt|date('d/m à H\\hi') }}{% endif %}. Le tarif actuel reste disponible tout de suite.</p>
                {% elseif product.hasPromotionPricing and product.promotionEndsAt and product.promotionActive %}
                    <p class="merch-product-promo-state">Prix promo actif{% if product.promotionEndsAt %} jusqu’au {{ product.promotionEndsAt|date('d/m') }}{% endif %}.</p>
                {% endif %}

                <div class="merch-product-trust">
                    <span>Paiement Stripe sécurisé</span>
                    <span>Expédition gérée avec Boxtal</span>
                    <span>Stocks suivis par variante</span>
                </div>

                {% if product.fitDetails or product.materialDetails or product.sizeGuideText or product.shippingDetails %}
                    <div class="merch-product-facts">
                        {% if product.fitDetails %}
                            <article class="merch-product-fact">
                                <strong>Coupe / format</strong>
                                <span>{{ product.fitDetails }}</span>
                            </article>
                        {% endif %}
                        {% if product.materialDetails %}
                            <article class="merch-product-fact">
                                <strong>Matière</strong>
                                <span>{{ product.materialDetails }}</span>
                            </article>
                        {% endif %}
                        {% if product.sizeGuideText %}
                            <article class="merch-product-fact">
                                <strong>Guide</strong>
                                <span>{{ product.sizeGuideText }}</span>
                            </article>
                        {% endif %}
                        {% if product.shippingDetails %}
                            <article class="merch-product-fact">
                                <strong>Expédition</strong>
                                <span>{{ product.shippingDetails }}</span>
                            </article>
                        {% endif %}
                    </div>
                {% endif %}

                <form method="post" action="{{ path('store_cart_add', {id: product.id}) }}" class="merch-product-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ product.id) }}">

                    {% if variants is not empty %}
                        <fieldset class="merch-product-options">
                            <legend>{{ product.variantChoiceLabel }}</legend>
                            <div class="merch-product-options__grid">
                                {% for variant in variants %}
                                    <label class="merch-product-option{% if not variant.isAvailable %} is-disabled{% endif %}">
                                        <input
                                            type="radio"
                                            name="variantId"
                                            value="{{ variant.id }}"
                                            data-option-input
                                            data-price="{{ variant.formattedPrice }}"
                                            data-price-cents="{{ variant.priceCents }}"
                                            data-compare-price="{{ product.promotionActive ? (variant.formattedCompareAtPrice ?: '') : '' }}"
                                            data-compare-price-cents="{{ product.promotionActive ? (variant.compareAtPriceCents ?: 0) : 0 }}"
                                            data-stock="{{ variant.stock }}"
                                            data-label="{{ variant.label }}"
                                            {% if selectedVariant and variant.id == selectedVariant.id %}checked{% endif %}
                                            {% if not variant.isAvailable %}disabled{% endif %}
                                        >
                                        <span class="merch-product-option__label">{{ variant.label }}</span>
                                        <span class="merch-product-option__meta">
                                            {{ variant.formattedPrice }}
                                            {% if variant.stock <= 0 %}· Rupture{% endif %}
                                        </span>
                                    </label>
                                {% endfor %}
                            </div>
                        </fieldset>
                    {% endif %}

                    {% if product.sizeGuideText %}
                        <p class="merch-product-guide-note">{{ product.sizeGuideText }}</p>
                    {% endif %}

                    <div class="merch-product-form__row">
                        <div class="field-shell">
                            <label class="field-label" for="quantity">Quantité</label>
                            <input
                                id="quantity"
                                type="number"
                                name="quantity"
                                min="1"
                                max="{{ selectedVariant ? selectedVariant.stock : product.displayStock }}"
                                value="1"
                                class="js-variant-quantity"
                            >
                        </div>
                        <button
                            class="button-primary merch-product-form__submit js-variant-submit"
                            type="submit"
                            {% if (selectedVariant and selectedVariant.stock <= 0) or (not selectedVariant and product.displayStock <= 0) %}disabled{% endif %}
                        >
                            Ajouter au panier
                        </button>
                    </div>
                    <p class="merch-product-form__note">Chaque achat soutient directement les futurs drops, les concerts et la fan base Sound Of Memories.</p>
                </form>

                <div class="merch-product-panels">
                    {% if product.category and product.category.description %}
                        <article class="merch-product-panel merch-product-panel--story">
                            <h2>Dans la collection {{ product.category.name }}</h2>
                            <p>{{ product.category.description }}</p>
                        </article>
                    {% endif %}

                    {% if product.description %}
                        <article class="merch-product-panel merch-product-panel--story">
                            <h2>Histoire de la pièce</h2>
                            <p>{{ product.description|nl2br }}</p>
                        </article>
                    {% endif %}

                    <article class="merch-product-panel">
                        <h2>Pourquoi elle mérite sa place dans le drop</h2>
                        <p>La fiche garde un achat très lisible : visuel fort, options claires, stock par variante, transport suivi et passage Stripe sans friction.</p>
                    </article>
                </div>
            </div>
        </div>
    </section>

    {% if relatedProducts is not empty %}
        <section class="section section-bg-2 merch-related-section">
            <div class="container">
                <header class="section-head merch-related-head">
                    <div>
                        <p class="eyebrow">À associer</p>
                        <h2>Compléter le drop avec d’autres pièces Sound Of Memories.</h2>
                    </div>
                    <a class="text-link" href="{{ path('store_shop_index') }}">Retour à la boutique</a>
                </header>

                <div class="merch-related-grid">
                    {% for relatedProduct in relatedProducts %}
                        <article class="merch-card merch-card--compact">
                            <a class="merch-card__media" href="{{ path('store_shop_show', {slug: relatedProduct.slug}) }}" aria-label="{{ relatedProduct.name }}">
                                {% include 'store/components/_product_media.html.twig' with {
                                    product: relatedProduct,
                                    media_classes: 'product-media merch-card__frame'
                                } only %}
                            </a>
                            <div class="merch-card__copy">
                                <p class="card-kicker">{{ relatedProduct.category ? relatedProduct.category.name : 'Merch' }}</p>
                                <h3><a href="{{ path('store_shop_show', {slug: relatedProduct.slug}) }}">{{ relatedProduct.name }}</a></h3>
                                <div class="merch-card__footer">
                                    <div class="merch-card__pricing">
                                        <strong>{{ relatedProduct.formattedStartingPrice }}</strong>
                                        <span>{{ relatedProduct.displayStock }} dispo</span>
                                    </div>
                                    <a class="button-secondary merch-card__button" href="{{ path('store_shop_show', {slug: relatedProduct.slug}) }}">Voir</a>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('scripts/shop-product.js') }}" defer></script>
{% endblock %}
