{% extends 'layouts/store.html.twig' %}

{% block title %}Boutique | Sound Of Memories{% endblock %}
{% block meta_description %}Boutique officielle Sound Of Memories. T-shirts, pins, posters, collectors et merch exclusif du groupe.{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/product-effects.css') }}">
{% endblock %}

{% block page %}
    <section class="section section-bg-1 shop-storefront">
        <div class="container shop-storefront-shell">
            <header class="shop-storefront-header">
                <div class="shop-storefront-copy">
                    <p class="eyebrow">Boutique officielle</p>
                    <h1>Le merch officiel Sound Of Memories.</h1>
                    <p>T-shirts, posters, pins et collectors en édition limitée. Chaque pièce porte l’ADN du groupe.</p>
                </div>
                <div class="shop-storefront-stats" aria-label="Repères boutique">
                    <span>{{ products|length }} pièce{{ products|length > 1 ? 's' : '' }}</span>
                    <span>Paiement sécurisé</span>
                    <span>Stock mis à jour</span>
                </div>
            </header>

            {% if featuredProduct %}
                <article class="merch-spotlight">
                    <div class="merch-spotlight__media">
                        <a href="{{ path('store_shop_show', {slug: featuredProduct.slug}) }}" aria-label="{{ featuredProduct.name }}">
                            {% include 'store/components/_product_media.html.twig' with {
                                product: featuredProduct,
                                media_classes: 'product-media merch-spotlight__frame'
                            } only %}
                        </a>
                    </div>
                    <div class="merch-spotlight__copy">
                        <p class="card-kicker">{{ featuredProduct.offerBannerEyebrow ?: 'Drop mis en avant' }}</p>
                        {% if featuredProduct.merchBadge %}
                            <span class="merch-badge merch-badge--{{ featuredProduct.merchBadgeTone }}">{{ featuredProduct.merchBadge }}</span>
                        {% endif %}
                        <h2>{{ featuredProduct.offerBannerTitle ?: featuredProduct.name }}</h2>
                        <p>{{ featuredProduct.offerBannerText ?: featuredProduct.catalogExcerpt ?: featuredProduct.shortDescription }}</p>
                        {% if featuredProduct.sellingPoints is not empty %}
                            <div class="merch-points">
                                {% for point in featuredProduct.sellingPoints|slice(0, 3) %}
                                    <span>{{ point }}</span>
                                {% endfor %}
                            </div>
                        {% endif %}
                        {% if featuredProduct.hasPromotionPricing %}
                            {% if featuredProduct.promotionUpcoming %}
                                <p class="merch-promo-note">Promo programmée{% if featuredProduct.promotionStartsAt %} à partir du {{ featuredProduct.promotionStartsAt|date('d/m') }}{% endif %}.</p>
                            {% elseif featuredProduct.displayCompareAtPriceCents %}
                                <p class="merch-promo-note">Prix promo actif en ce moment sur cette pièce.</p>
                            {% endif %}
                        {% endif %}
                        <div class="merch-spotlight__meta">
                            <strong>{{ featuredProduct.formattedStartingPrice }}</strong>
                            <span>{{ featuredProduct.displayStock }} en stock</span>
                            {% if featuredProduct.publishedVariants|length > 0 %}
                                <span>{{ featuredProduct.publishedVariants|length }} option{{ featuredProduct.publishedVariants|length > 1 ? 's' : '' }}</span>
                            {% endif %}
                        </div>
                        <div class="button-row">
                            <a class="button-primary" href="{{ path('store_shop_show', {slug: featuredProduct.slug}) }}">Acheter maintenant</a>
                            <a class="button-secondary" href="#catalogue">Voir tout le catalogue</a>
                        </div>
                    </div>
                </article>
            {% endif %}

            {% if categories is not empty %}
                <nav class="merch-category-nav" aria-label="Catégories boutique">
                    {% for category in categories %}
                        {% set group = productsByCategory|filter(item => item.category and item.category.id == category.id)|first %}
                        {% set productCount = group ? group.products|length : 0 %}
                        <a href="#category-{{ category.slug }}">
                            <span>{{ category.name }}</span>
                            <small>{{ productCount }} pièce{{ productCount > 1 ? 's' : '' }}</small>
                        </a>
                    {% endfor %}
                </nav>
            {% endif %}
        </div>
    </section>

    <section class="section section-bg-2 shop-shelves-section" id="catalogue">
        <div class="container shop-shelves">
            {% for group in productsByCategory %}
                {% set category = group.category %}
                <section class="merch-shelf" id="{{ category ? 'category-' ~ category.slug : 'category-merch' }}">
                    <header class="merch-shelf__header">
                        <div>
                            <p class="eyebrow">{{ category ? category.name : 'Merch' }}</p>
                            <h2>{{ category ? category.name : 'Autres pièces' }}</h2>
                            <p class="merch-shelf__count">{{ group.products|length }} référence{{ group.products|length > 1 ? 's' : '' }}</p>
                        </div>
                        <p>{{ category and category.description ? category.description : 'Une sélection simple à parcourir, pensée pour la scène, la collection ou le quotidien.' }}</p>
                    </header>

                    <div class="merch-shelf__grid">
                        {% for product in group.products %}
                            <article class="merch-card">
                                <a class="merch-card__media" href="{{ path('store_shop_show', {slug: product.slug}) }}" aria-label="{{ product.name }}">
                                    {% include 'store/components/_product_media.html.twig' with {
                                        product: product,
                                        media_classes: 'product-media merch-card__frame'
                                    } only %}
                                </a>

                                <div class="merch-card__copy">
                                    <div class="merch-card__head">
                                        <div class="merch-card__heading-meta">
                                            <p class="card-kicker">{{ product.category ? product.category.name : 'Merch' }}</p>
                                            {% if product.merchBadge %}
                                                <span class="merch-badge merch-badge--{{ product.merchBadgeTone }}">{{ product.merchBadge }}</span>
                                            {% elseif product.promotionUpcoming %}
                                                <span class="merch-badge merch-badge--sand">Promo bientôt</span>
                                            {% endif %}
                                        </div>
                                        {% if product.displayCompareAtPriceCents %}
                                            <span class="merch-card__compare">{{ product.formattedDisplayCompareAtPrice }}</span>
                                        {% endif %}
                                    </div>

                                    <h3><a href="{{ path('store_shop_show', {slug: product.slug}) }}" aria-label="{{ product.name }}">{{ product.name }}</a></h3>
                                    <p>{{ product.catalogExcerpt ?: product.shortDescription }}</p>
                                    {% if product.sellingPoints is not empty %}
                                        <div class="merch-points merch-points--compact">
                                            {% for point in product.sellingPoints|slice(0, 2) %}
                                                <span>{{ point }}</span>
                                            {% endfor %}
                                        </div>
                                    {% endif %}

                                    <div class="merch-card__footer">
                                        <div class="merch-card__pricing">
                                            <strong>{{ product.formattedStartingPrice }}</strong>
                                            <span>{{ product.displayStock }} dispo</span>
                                        </div>
                                        <a class="button-secondary merch-card__button" href="{{ path('store_shop_show', {slug: product.slug}) }}">
                                            {{ product.hasVariants ? 'Choisir ' ~ product.variantChoiceLabel|lower : 'Voir le produit' }}
                                        </a>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                </section>
            {% else %}
                <article class="empty-card shop-empty-card">
                    <h2>Boutique vide</h2>
                    <p>Ajoutez vos premiers produits depuis le backstage pour alimenter le catalogue.</p>
                </article>
            {% endfor %}
        </div>
    </section>

    {% include 'components/_farewell.html.twig' %}
{% endblock %}
