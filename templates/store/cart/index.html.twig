{% extends 'layouts/store.html.twig' %}

{% block title %}Panier | Sound Of Memories{% endblock %}

{% block page %}
    <section class="section section-bg-1 merch-cart-section">
        <div class="container merch-cart-header">
            <div>
                <p class="eyebrow">Panier</p>
                <h1>Votre drop Sound Of Memories est presque prêt.</h1>
                <p>Vérifiez les variantes, ajustez les quantités et passez au paiement sécurisé sans détour.</p>
            </div>
            <div class="merch-cart-header__meta">
                <span>{{ items|length }} ligne{{ items|length > 1 ? 's' : '' }}</span>
                <span>Stripe sécurisé</span>
                <span>Expédition Boxtal</span>
                {% if savingsCents > 0 %}
                    <span>Économie {{ (savingsCents / 100)|number_format(2, ',', ' ') }} EUR</span>
                {% endif %}
            </div>
        </div>
    </section>

    <section class="section section-bg-2 merch-cart-body">
        <div class="container merch-cart-layout">
            <div class="merch-cart-items">
                {% for item in items %}
                    {% set mediaUrl = item.product.coverImage
                        ? (item.product.coverImage starts with 'http' or item.product.coverImage starts with '/'
                            ? item.product.coverImage
                            : asset('uploads/products/' ~ item.product.coverImage))
                        : null
                    %}
                    <article class="merch-cart-item">
                        <a class="merch-cart-item__media" href="{{ path('store_shop_show', {slug: item.product.slug}) }}" aria-label="{{ item.product.name }}">
                            {% if mediaUrl %}
                                <img src="{{ mediaUrl }}" alt="{{ item.product.name }}" width="320" height="320" loading="lazy" decoding="async">
                            {% else %}
                                <span>Visuel à venir</span>
                            {% endif %}
                        </a>

                        <div class="merch-cart-item__copy">
                            <p class="card-kicker">{{ item.product.category ? item.product.category.name : 'Merch' }}</p>
                            <h2><a href="{{ path('store_shop_show', {slug: item.product.slug}) }}">{{ item.product.name }}</a></h2>
                            {% if item.variant %}
                                <p class="merch-cart-item__variant">{{ item.product.variantChoiceLabel }} : {{ item.variant.label }}</p>
                            {% endif %}
                            <p>{{ item.product.shortDescription ?: item.product.catalogExcerpt }}</p>
                            <div class="merch-cart-item__pricing">
                                <strong>{{ (item.unitPriceCents / 100)|number_format(2, ',', ' ') }} EUR</strong>
                                {% if item.compareAtPriceCents and item.compareAtPriceCents > item.unitPriceCents %}
                                    <span class="merch-cart-item__compare">{{ (item.compareAtPriceCents / 100)|number_format(2, ',', ' ') }} EUR</span>
                                {% endif %}
                                <span>{{ item.availableStock }} dispo</span>
                            </div>
                            {% if item.product.sellingPoints is not empty %}
                                <div class="merch-points merch-points--compact">
                                    {% for point in item.product.sellingPoints|slice(0, 2) %}
                                        <span>{{ point }}</span>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="merch-cart-item__actions">
                            <form method="post" action="{{ path('store_cart_update') }}" class="merch-cart-item__qty-form">
                                <input type="hidden" name="itemKey" value="{{ item.cartKey }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('cart_update_' ~ item.cartKey) }}">
                                <label class="field-label" for="qty-{{ loop.index }}">Quantité</label>
                                <input id="qty-{{ loop.index }}" type="number" name="quantity" min="0" max="{{ item.availableStock }}" value="{{ item.quantity }}">
                                <button class="button-secondary" type="submit">Mettre à jour</button>
                            </form>

                            <div class="merch-cart-item__total">
                                <span>Total ligne</span>
                                <strong>{{ (item.totalCents / 100)|number_format(2, ',', ' ') }} EUR</strong>
                            </div>

                            <form method="post" action="{{ path('store_cart_remove') }}">
                                <input type="hidden" name="itemKey" value="{{ item.cartKey }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('cart_remove_' ~ item.cartKey) }}">
                                <button class="button-ghost" type="submit">Retirer</button>
                            </form>
                        </div>
                    </article>
                {% else %}
                    <article class="empty-card">
                        <h2>Le panier est vide</h2>
                        <p>Ajoutez quelques pièces de merch pour lancer un vrai parcours d’achat.</p>
                        <a class="button-primary" href="{{ path('store_shop_index') }}">Découvrir la boutique</a>
                    </article>
                {% endfor %}
            </div>

            <aside class="merch-cart-summary">
                <p class="eyebrow">Résumé</p>
                <h2>Total estimé</h2>
                <strong class="merch-cart-summary__total">{{ (totalCents / 100)|number_format(2, ',', ' ') }} EUR</strong>
                <p class="merch-cart-summary__note">La livraison et les réductions éventuelles seront confirmées au checkout selon la destination.</p>
                <div class="merch-cart-summary__trust">
                    <span>Paiement sécurisé</span>
                    <span>Stocks par variante</span>
                    <span>Support fan base</span>
                </div>

                <div class="merch-cart-summary__list">
                    {% for item in items %}
                        <div class="summary-line">
                            <span>{{ item.displayName }} x{{ item.quantity }}</span>
                            <strong>{{ (item.totalCents / 100)|number_format(2, ',', ' ') }} EUR</strong>
                        </div>
                    {% endfor %}
                </div>

                <div class="button-column">
                    <a class="button-primary" href="{{ path('store_checkout') }}">Continuer la commande</a>
                    <a class="button-secondary" href="{{ path('store_shop_index') }}">Revenir au catalogue</a>
                </div>
            </aside>
        </div>
    </section>

    {% if recommendedProducts is not empty %}
        <section class="section section-bg-3 merch-related-section">
            <div class="container">
                <header class="section-head merch-related-head">
                    <div>
                        <p class="eyebrow">Compléter le drop</p>
                        <h2>Quelques pièces qui s’ajoutent naturellement à votre panier.</h2>
                    </div>
                    <p class="account-section-subtitle">Des produits choisis dans les mêmes univers merch pour rendre le panier plus cohérent.</p>
                </header>

                <div class="merch-related-grid">
                    {% for product in recommendedProducts %}
                        <article class="merch-card merch-card--compact">
                            <a class="merch-card__media" href="{{ path('store_shop_show', {slug: product.slug}) }}" aria-label="{{ product.name }}">
                                {% include 'store/components/_product_media.html.twig' with {
                                    product: product,
                                    media_classes: 'product-media merch-card__frame'
                                } only %}
                            </a>

                            <div class="merch-card__copy">
                                <div class="merch-card__heading-meta">
                                    <p class="card-kicker">{{ product.category ? product.category.name : 'Merch' }}</p>
                                    {% if product.merchBadge %}
                                        <span class="merch-badge merch-badge--{{ product.merchBadgeTone }}">{{ product.merchBadge }}</span>
                                    {% endif %}
                                </div>
                                <h3><a href="{{ path('store_shop_show', {slug: product.slug}) }}">{{ product.name }}</a></h3>
                                <p>{{ product.catalogExcerpt ?: product.shortDescription }}</p>
                                <div class="merch-card__footer">
                                    <div class="merch-card__pricing">
                                        <strong>{{ product.formattedStartingPrice }}</strong>
                                        <span>{{ product.displayStock }} dispo</span>
                                    </div>
                                    <a class="button-secondary merch-card__button" href="{{ path('store_shop_show', {slug: product.slug}) }}">Voir le produit</a>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}
{% endblock %}
