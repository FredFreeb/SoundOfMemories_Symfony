{% extends 'layouts/store.html.twig' %}

{% block title %}Mentions légales | Sound Of Memories{% endblock %}
{% block meta_description %}Mentions légales du site Sound Of Memories : informations de propriété, gestion du site, hébergement et contact.{% endblock %}
{% block meta_robots %}index,follow{% endblock %}

{% block page %}
    <section class="page-banner page-banner--bg-1">
        <div class="container">
            <p class="eyebrow">Informations légales</p>
            <h1>Mentions légales</h1>
            <p>Cette page rassemble les informations essentielles relatives à la propriété, à la gestion et à l'hébergement du site.</p>
        </div>
    </section>

    <section class="section section-bg-1">
        <div class="container faq-list">
            <article class="faq-item">
                <h2>Éditeur du site</h2>
                <p><strong>Nom du site :</strong> Sound Of Memories</p>
                <p><strong>Propriétaire du site :</strong> {{ site_owner.ownerName }}</p>
                <p><strong>Gestion du site :</strong> administration technique du site</p>
                <p><strong>Adresse :</strong> {{ site_owner.ownerAddress }}</p>
                <p><strong>Contact :</strong> {{ site_owner.ownerEmail }}</p>
            </article>

            <article class="faq-item">
                <h2>Hébergement</h2>
                <p><strong>Hébergeur prévu :</strong> Hostinger</p>
                <p><strong>Type d'hébergement :</strong> VPS avec pile Docker / Symfony</p>
                <p><strong>Coordonnées :</strong> à compléter selon l'offre Hostinger effectivement utilisée</p>
            </article>

            <article class="faq-item">
                <h2>Propriété intellectuelle</h2>
                <p>Les textes, visuels, graphismes, animations, logos, produits et contenus du site sont protégés par le droit applicable à la propriété intellectuelle, sauf mention contraire.</p>
                <p>Toute reproduction, représentation, diffusion ou exploitation, totale ou partielle, sans autorisation préalable, est interdite.</p>
            </article>

            <article class="faq-item">
                <h2>Pages légales associées</h2>
                <p><a class="text-link" href="{{ path('store_cgv') }}">Consulter les conditions générales de vente</a></p>
                <p><a class="text-link" href="{{ path('store_privacy') }}">Consulter la politique de confidentialité</a></p>
            </article>

        </div>
    </section>
{% endblock %}
