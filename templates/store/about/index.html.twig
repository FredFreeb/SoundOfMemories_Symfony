{% extends 'layouts/store.html.twig' %}

{% block title %}The Band | Sound Of Memories{% endblock %}
{% block meta_description %}Sound Of Memories, groupe de death mélodique né en 2010 entre Paris et l'Essonne. Histoire, membres, discographie et univers du groupe.{% endblock %}
{% block stylesheets %}
    {% set aboutHero = editorial.hero ?? null %}
    {% if aboutHero and aboutHero.imagePath %}
        {% set aboutHeroImagePath = aboutHero.imagePath starts with 'uploads/' ? aboutHero.imagePath : 'uploads/editorial/' ~ aboutHero.imagePath|trim('/') %}
        <link rel="preload" as="image" href="{{ asset(aboutHeroImagePath) }}">
    {% endif %}
    {{ parent() }}
{% endblock %}

{% block page %}
    {# ── Use editorial modules if they exist, otherwise show static content ── #}
    {% if editorial.hero is defined and editorial.hero is not null %}
        {% include 'components/editorial/_module_manifesto_hero.html.twig' with { module: editorial.hero } only %}
    {% else %}
        <section class="page-banner page-banner--band" style="--banner-image: url('{{ asset('uploads/legacy/gal14.JPG') }}');">
            <div class="container editorial-band-hero__layout">
                <div class="editorial-band-hero__copy">
                    <p class="eyebrow">The Band</p>
                    <h1>Sound Of Memories</h1>
                    <p class="editorial-band-hero__lead">Métal mélodique forgé entre Paris et l'Essonne depuis 2010. Entre death mélodique, heavy et thrash, un son qui ne s'oublie pas.</p>
                    <div class="editorial-band-hero__meta">
                        <span>Melodic Death Metal</span>
                        <span>Paris, France</span>
                        <span>Since 2010</span>
                    </div>
                </div>
                <figure class="editorial-band-hero__visual">
                    <img src="{{ asset('uploads/legacy/about.JPG') }}" alt="Sound Of Memories — photo du groupe" width="1409" height="939" fetchpriority="high" decoding="async">
                </figure>
            </div>
        </section>
    {% endif %}

    {% if editorial.story is defined and editorial.story is not null %}
        {% include 'components/editorial/_module_story_block.html.twig' with { module: editorial.story } only %}
    {% else %}
        <section class="section section-bg-1 editorial-story-section">
            <div class="container editorial-story-layout">
                <div class="editorial-story-copy">
                    <p class="eyebrow">Our Story</p>
                    <h2>Né du besoin de créer quelque chose de viscéral.</h2>
                    <p class="editorial-story-copy__lead">Sound Of Memories naît en 2010 d'une envie commune : fusionner la puissance du death mélodique avec des atmosphères cinématiques et des mélodies qui restent gravées.</p>

                    <div class="editorial-story-copy__body">
                        <p>Le groupe se forme dans le sud de Paris, porté par une fascination pour les contrastes sonores — la brutalité et la beauté, la violence et l'émotion. Dès les premières répétitions, le son prend forme : des riffs tranchants, des leads aériens, une section rythmique massive et des compositions qui osent la longueur et la narration.</p>
                        <p>Les premiers concerts confirment la direction. Les scènes parisiennes — Le Batofar, La Boule Noire, Le Petit Bain — deviennent le terrain de jeu du groupe. L'énergie live est frontale, organique, sans concession. C'est sur scène que Sound Of Memories prend toute sa dimension.</p>
                        <p>Avec "Living Circles" en 2013, "To Deliverance" en 2015 puis "The Sand Within" en 2020, le groupe affirme sa signature : un metal mélodique qui ne sacrifie ni la technique ni l'émotion, avec une production soignée et une identité visuelle forte.</p>
                    </div>
                </div>

                <div class="editorial-story-visual">
                    <figure class="editorial-story-visual__figure">
                        <img src="{{ asset('uploads/legacy/gal5.JPG') }}" alt="Sound Of Memories en concert" width="1409" height="939" loading="lazy" decoding="async">
                    </figure>
                    <div class="editorial-story-visual__note">
                        <span>3 albums / EPs</span>
                        <span>50+ concerts</span>
                        <span>Paris &amp; Île-de-France</span>
                    </div>
                </div>
            </div>
        </section>
    {% endif %}

    {% if editorial.lineup is defined and editorial.lineup is not null %}
        {% include 'components/editorial/_module_lineup_grid.html.twig' with { module: editorial.lineup } only %}
    {% else %}
        <section class="section section-bg-2 band-lineup-section">
            <div class="container">
                <div class="editorial-section-head">
                    <div>
                        <p class="eyebrow">Lineup</p>
                        <h2>Les visages derrière le son.</h2>
                        <p class="editorial-section-head__lead">Chaque membre apporte sa couleur, son énergie et sa vision. Ensemble, ils forment le mur sonore Sound Of Memories.</p>
                    </div>
                </div>

                <div class="editorial-lineup-grid">
                    <div class="editorial-member-card">
                        <p class="eyebrow">Guitare / Composition</p>
                        <figure class="editorial-member-card__portrait" aria-hidden="true">
                            <span>A</span>
                        </figure>
                        <h3>Alain</h3>
                        <p class="editorial-member-card__subtitle">Guitare</p>
                        <p>Guitares tranchantes, mélodies en tension et énergie frontale. Alain pose l'une des signatures sonores du groupe.</p>
                    </div>
                    <div class="editorial-member-card">
                        <p class="eyebrow">Guitare</p>
                        <figure class="editorial-member-card__portrait" aria-hidden="true">
                            <span>L</span>
                        </figure>
                        <h3>Lucho</h3>
                        <p class="editorial-member-card__subtitle">Guitare</p>
                        <p>Riffs incisifs, attaques nettes et présence scénique immédiate. Lucho renforce la puissance et l'ampleur des morceaux.</p>
                    </div>
                    <div class="editorial-member-card">
                        <p class="eyebrow">Basse</p>
                        <figure class="editorial-member-card__portrait" aria-hidden="true">
                            <span>F</span>
                        </figure>
                        <h3>Fabien</h3>
                        <p class="editorial-member-card__subtitle">Basse</p>
                        <p>Le socle grave qui relie les guitares à la batterie. Fabien donne au son sa profondeur, son poids et sa tenue.</p>
                    </div>
                    <div class="editorial-member-card">
                        <p class="eyebrow">Batterie</p>
                        <figure class="editorial-member-card__portrait" aria-hidden="true">
                            <span>N</span>
                        </figure>
                        <h3>Nacim</h3>
                        <p class="editorial-member-card__subtitle">Batterie</p>
                        <p>La frappe qui propulse chaque titre. Nacim alterne tension, impact et précision pour faire avancer tout le set.</p>
                    </div>
                    <div class="editorial-member-card">
                        <p class="eyebrow">Voix</p>
                        <figure class="editorial-member-card__portrait" aria-hidden="true">
                            <span>F</span>
                        </figure>
                        <h3>Flo</h3>
                        <p class="editorial-member-card__subtitle">Chant</p>
                        <p>Une voix portée par l'intensité et le relief émotionnel. Flo donne son souffle, sa rage et sa présence aux morceaux.</p>
                    </div>
                </div>
            </div>
        </section>
    {% endif %}

    {% if editorial.discography is defined and editorial.discography is not null %}
        {% include 'components/editorial/_module_release_grid.html.twig' with { module: editorial.discography } only %}
    {% else %}
        <section class="section section-bg-3 band-discography-section">
            <div class="container">
                <div class="editorial-section-head">
                    <div>
                        <p class="eyebrow">Discography</p>
                        <h2>Chaque album, une étape.</h2>
                        <p class="editorial-section-head__lead">De "Living Circles" en 2013 à "The Sand Within" en 2020, trois sorties qui racontent l'évolution du son Sound Of Memories.</p>
                    </div>
                </div>

                <div class="editorial-release-grid">
                    <div class="editorial-release-card">
                        <figure class="editorial-release-card__cover">
                            <img src="{{ asset('uploads/legacy/Living.jpg') }}" alt="Living Circles — pochette" loading="lazy" decoding="async">
                        </figure>
                        <div class="editorial-release-card__copy">
                            <p class="card-kicker">2013</p>
                            <h3>Living Circles</h3>
                            <p class="editorial-release-card__subtitle">EP</p>
                            <p>Le premier souffle studio du groupe. Une sortie fondatrice, déjà marquée par la tension mélodique et une vraie intensité d'écriture.</p>
                            <div class="editorial-release-card__meta">
                                <span>Première sortie</span>
                                <span>Melodic Death Metal</span>
                                <span>3 titres</span>
                            </div>
                        </div>
                    </div>
                    <div class="editorial-release-card">
                        <figure class="editorial-release-card__cover">
                            <img src="{{ asset('uploads/legacy/Deliv.jpg') }}" alt="To Deliverance — pochette" loading="lazy" decoding="async">
                        </figure>
                        <div class="editorial-release-card__copy">
                            <p class="card-kicker">2015</p>
                            <h3>To Deliverance</h3>
                            <p class="editorial-release-card__subtitle">Album</p>
                            <p>Une étape plus sombre, plus massive et plus frontale. Le groupe y durcit son écriture et renforce sa signature entre death, thrash et heavy.</p>
                            <div class="editorial-release-card__meta">
                                <span>Death / Thrash / Heavy</span>
                                <span>10 titres</span>
                                <span>Album</span>
                            </div>
                        </div>
                    </div>
                    <div class="editorial-release-card">
                        <figure class="editorial-release-card__cover">
                            <img src="{{ asset('uploads/legacy/SofM-cover.png') }}" alt="The Sand Within — pochette" loading="lazy" decoding="async">
                        </figure>
                        <div class="editorial-release-card__copy">
                            <p class="card-kicker">2020</p>
                            <h3>The Sand Within</h3>
                            <p class="editorial-release-card__subtitle">Album</p>
                            <p>Une matière plus vaste, plus sombre et plus cinématique. Le groupe y affine son identité entre violence contenue, mélodie et puissance évocatrice.</p>
                            <div class="editorial-release-card__meta">
                                <span>Metal / Melodic Death</span>
                                <span>10 titres</span>
                                <span>Album</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    {% endif %}
    {% include 'components/_farewell.html.twig' %}
{% endblock %}
