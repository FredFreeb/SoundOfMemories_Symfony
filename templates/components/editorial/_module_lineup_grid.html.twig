{% if module is not null %}
    <section class="section {{ module.backgroundSlot }} editorial-lineup-section">
        <div class="container section-head editorial-section-head">
            <div data-editorial-module="story-block" data-editorial-tone="{{ module.accentTone }}">
                {% if module.eyebrow %}
                    <p class="eyebrow">{{ module.eyebrow }}</p>
                {% endif %}
                <h2 data-editorial-copy>{{ module.title }}</h2>
                {% if module.leadText %}
                    <p class="editorial-section-head__lead">{{ module.leadText }}</p>
                {% endif %}
            </div>
        </div>

        <div class="container editorial-lineup-grid">
            {% for item in module.publishedItems %}
                <article class="editorial-member-card">
                    {% if item.eyebrow %}
                        <p class="card-kicker">{{ item.eyebrow }}</p>
                    {% endif %}
                    {% set portrait = editorial_asset(item.imagePath) %}
                    <figure class="editorial-member-card__portrait"{% if not portrait %} aria-hidden="true"{% endif %}>
                        {% if portrait %}
                            <img src="{{ portrait }}" alt="{{ item.title }} — portrait" loading="lazy" decoding="async">
                        {% else %}
                            <span>{{ item.title|slice(0, 1)|upper }}</span>
                        {% endif %}
                    </figure>
                    <h3>{{ item.title }}</h3>
                    {% if item.subtitle %}
                        <p class="editorial-member-card__subtitle">{{ item.subtitle }}</p>
                    {% endif %}
                    {% if item.bodyText %}
                        <p>{{ item.bodyText }}</p>
                    {% endif %}
                </article>
            {% endfor %}
        </div>
    </section>
{% endif %}
