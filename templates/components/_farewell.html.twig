{#
  Composant réutilisable — annonce de séparation du groupe + liens projets solos.
  Inclure avec : {% include 'components/_farewell.html.twig' %}
  Données injectées via Twig globals (band_separation_year, member_link_*).
#}

{% set soloMembers = [
    { name: 'Alain',  role: 'Guitare',   url: member_link_alain  },
    { name: 'Lucho',  role: 'Guitare',   url: member_link_lucho  },
    { name: 'Fabien', role: 'Basse',     url: member_link_fabien },
    { name: 'Nacim',  role: 'Batterie',  url: member_link_nacim  },
    { name: 'Flo',    role: 'Chant',     url: member_link_flo    },
] %}

<section class="section section-bg-none farewell-section">
    <div class="container farewell-layout">

        <div class="farewell-statement">
            <p class="eyebrow">{{ band_separation_year }} — Séparation</p>
            <h2>Sound Of Memories s'est séparé en {{ band_separation_year }}.</h2>
            <p>Merci à tous ceux qui ont partagé cette aventure — chaque concert, chaque note, chaque visage dans la fosse. Les albums restent, les souvenirs aussi.</p>
            <div class="button-row">
                <a class="button-secondary" href="{{ path('store_gallery') }}">Voir la galerie</a>
                <a class="button-secondary" href="{{ path('store_shop_index') }}">Merch restant</a>
            </div>
        </div>

        <div class="farewell-solos">
            <p class="eyebrow">Projets solos</p>
            <ul class="farewell-solos__list" aria-label="Projets solos des membres">
                {% for member in soloMembers %}
                    <li class="farewell-solos__item">
                        <div class="farewell-solos__identity">
                            <span class="farewell-solos__avatar" aria-hidden="true">{{ member.name|slice(0,1) }}</span>
                            <div>
                                <strong>{{ member.name }}</strong>
                                <span>{{ member.role }}</span>
                            </div>
                        </div>
                        {% if member.url %}
                            <a class="farewell-solos__link"
                               href="{{ member.url }}"
                               target="_blank"
                               rel="noopener noreferrer"
                               aria-label="Projet solo de {{ member.name }}">
                                Projet solo
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <line x1="7" y1="17" x2="17" y2="7"/>
                                    <polyline points="7 7 17 7 17 17"/>
                                </svg>
                            </a>
                        {% else %}
                            <span class="farewell-solos__tba">À venir</span>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        </div>

    </div>
</section>
