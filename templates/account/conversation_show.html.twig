{% extends 'layouts/store.html.twig' %}

{% block title %}{{ conversation.subject }}{% endblock %}
{% block meta_robots %}noindex,nofollow{% endblock %}

{% block page %}
    <section class="page-banner">
        <div class="container dossier-grid">
            <div class="detail-content">
                <p class="eyebrow">{{ conversation.type == 'order_support' ? 'Support commande' : 'Question avant achat' }}</p>
                <h1>{{ conversation.subject }}</h1>
                <p>Retrouvez ici tout l’historique de vos échanges avec le service client.</p>
                <div class="account-meta">
                    <span>{{ conversation.statusLabel }}</span>
                    <span>{{ conversation.lastMessageAt|date('d/m/Y H:i') }}</span>
                </div>
            </div>

            <aside class="detail-panel">
                <p class="eyebrow">Conversation</p>
                <h2>Référence</h2>
                {% if conversation.orderRef %}
                    <p>Commande #{{ conversation.orderRef.id }}</p>
                {% else %}
                    <p>Question générale avant achat</p>
                {% endif %}
                <a class="text-link" href="{{ path('app_account') }}">Retour à mon compte</a>
            </aside>
        </div>
    </section>

    <section class="section section-bg-1">
        <div class="container account-chat-layout">
            <article class="detail-panel account-chat-panel account-chat-thread-panel managed-container-surface managed-container-surface-type-2">
                <div class="account-chat-thread-head">
                    <div>
                        <p class="eyebrow">Fil de discussion</p>
                        <h2>Conversation en cours</h2>
                    </div>
                    <span class="stock-pill">{{ conversation.messages|length }} message{{ conversation.messages|length > 1 ? 's' : '' }}</span>
                </div>

                <div class="account-message-thread" role="log" aria-live="polite" data-chat-thread="conversation">
                    {% for message in conversation.messages %}
                        <article class="account-message-row {{ message.authorType == 'client' ? 'is-client' : 'is-admin' }}" data-message-author-type="{{ message.authorType }}">
                            <div class="account-message-shell">
                                <div class="account-message-label">
                                    <strong>{{ message.authorType == 'client' ? 'Vous' : 'Service client' }}</strong>
                                    <span>{{ message.createdAt|date('d/m/Y H:i') }}</span>
                                </div>
                                <article class="account-message {{ message.authorType == 'client' ? 'is-client' : 'is-admin' }}">
                                    <div class="account-message-meta">
                                        <strong>{{ message.authorName }}</strong>
                                        <span>{{ message.createdAt|date('d/m/Y H:i') }}</span>
                                    </div>
                                    <p>{{ message.body|e|nl2br }}</p>
                                </article>
                            </div>
                        </article>
                    {% else %}
                        <article class="empty-state">
                            <h3>Conversation vide</h3>
                            <p>Écrivez votre premier message pour démarrer l’échange.</p>
                        </article>
                    {% endfor %}
                </div>
            </article>

            <aside class="detail-panel account-chat-panel account-chat-compose-panel managed-container-surface managed-container-surface-type-2">
                <div class="account-chat-compose-card">
                    <div class="account-chat-compose-copy">
                        <p class="eyebrow">Répondre</p>
                        <h2>Envoyer un message</h2>
                        <p class="account-section-subtitle">Votre réponse s’ajoute au fil et reste visible dans l’historique de la conversation.</p>
                    </div>

                    <div class="account-chat-compose-badges" aria-label="Informations de composition">
                        <span class="stock-pill">Réponse humaine</span>
                        <span class="stock-pill account-compose-pill-muted">Historique conservé</span>
                    </div>

                    {{ form_start(replyForm, {attr: {class: 'account-chat-compose-form'}}) }}
                        <div class="account-chat-compose-field">
                            {{ form_row(replyForm.body, {attr: {placeholder: 'Décrivez votre question, un complément ou une précision utile…'}}) }}
                        </div>
                        <div class="account-chat-compose-actions">
                            <p class="account-chat-compose-hint">Le message sera envoyé au service client et ajouté immédiatement à l’historique.</p>
                            <button class="button-primary" type="submit">Envoyer le message</button>
                        </div>
                    {{ form_end(replyForm) }}
                </div>

                <div class="account-assistant-note" data-ai-ready="true">
                    <p class="eyebrow">Assistant</p>
                    <h3>Base prête pour l’IA</h3>
                    <p>Le fil distingue déjà le client et le service client. On pourra ensuite y brancher un brouillon de réponse, une reformulation ou un résumé, tout en gardant une validation humaine avant envoi.</p>
                </div>
            </aside>
        </div>
    </section>
{% endblock %}
