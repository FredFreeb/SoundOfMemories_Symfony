{% extends 'layouts/store.html.twig' %}

{% block title %}Nouvelle conversation{% endblock %}
{% block meta_robots %}noindex,nofollow{% endblock %}

{% block page %}
    <section class="page-banner">
        <div class="container account-page-shell">
            <div class="detail-content">
                <p class="eyebrow">Service client</p>
                <h1>Ouvrir une nouvelle conversation</h1>
                <p>Utilisez cet espace pour poser une question avant achat ou demander un renseignement général sur une enquête.</p>
            </div>
        </div>
    </section>

    <section class="section section-bg-1">
        <div class="container account-page-shell">
            <article class="detail-panel account-chat-panel managed-container-surface managed-container-surface-type-2">
                {{ form_start(conversationForm) }}
                    {{ form_row(conversationForm.subject) }}
                    {{ form_row(conversationForm.body) }}
                    <div class="account-page-actions">
                        <button class="button-primary" type="submit">Envoyer ma demande</button>
                        <a class="text-link" href="{{ path('app_account') }}">Retour à mon compte</a>
                    </div>
                {{ form_end(conversationForm) }}
            </article>
        </div>
    </section>
{% endblock %}
