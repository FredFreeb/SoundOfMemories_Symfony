{% extends 'layouts/store.html.twig' %}

{% block title %}Commande #{{ order.id }}{% endblock %}
{% block meta_description %}Détail d'une commande Sound Of Memories avec suivi, paiement et récapitulatif des produits.{% endblock %}
{% block meta_robots %}noindex,nofollow{% endblock %}

{% block page %}
    <section class="page-banner">
        <div class="container dossier-grid">
            <div class="detail-content">
                <p class="eyebrow">Commande #{{ order.id }}</p>
                <h1>Suivi de l'expédition</h1>
                <p>Retrouvez ici un récapitulatif clair de la commande, du paiement et de la livraison.</p>
                <div class="account-meta">
                    <span>Statut : {{ order.statusLabel }}</span>
                    <span>Paiement : {{ order.paymentStatusLabel }}</span>
                    <span>Livraison : {{ order.deliveryStatusLabel }}</span>
                    {% if order.paidAt %}<span>Payé le {{ order.paidAt|date('d/m/Y H:i') }}</span>{% endif %}
                </div>
            </div>

            <aside class="detail-panel">
                <p class="eyebrow">Livraison</p>
                <p>{{ order.customerName }}</p>
                <p>{{ order.shippingAddress ?: 'Adresse non renseignée' }}</p>
                <p>{{ order.postalCode }} {{ order.city }}</p>
                <p>{{ order.shippingCountryLabel }}</p>
                <p>{{ order.customerEmail }}</p>
                {% if order.shippingMethodLabel %}
                    <p>Mode : {{ order.shippingMethodLabel }}</p>
                {% endif %}
                {% if order.shippingRateCents > 0 %}
                    <p>Port : {{ order.formattedShippingRate }}</p>
                {% endif %}
                {% if order.shippingCarrier %}
                    <p>Transporteur : {{ order.shippingCarrier }}</p>
                {% endif %}
                {% if order.trackingNumber %}
                    <p>Suivi : {{ order.trackingNumber }}</p>
                {% endif %}
                {% if order.trackingUrl %}
                    <a class="text-link" href="{{ order.trackingUrl }}" target="_blank" rel="noopener noreferrer">Suivre le colis</a>
                {% endif %}
                <a class="button-secondary" href="{{ path('app_account_order_support', {id: order.id}) }}">
                    {{ orderConversation ? 'Ouvrir le chat service client' : 'Contacter le service client' }}
                </a>
            </aside>
        </div>
    </section>

    <section class="section section-bg-1">
        <div class="container feature-columns">
            {% for item in order.items %}
                <article class="dossier-card">
                    <h2>{{ item.displayName }}</h2>
                    <p>Quantité : {{ item.quantity }}</p>
                    <p>Prix unitaire : {{ (item.unitPriceCents / 100)|number_format(2, ',', ' ') }} EUR</p>
                </article>
            {% endfor %}
            <article class="dossier-card">
                <h2>Récapitulatif</h2>
                <p>Sous-total : {{ order.formattedSubtotal }}</p>
                {% if order.discountCents > 0 %}
                    <p>{{ order.discountLabel }} : -{{ order.formattedDiscount }}</p>
                {% endif %}
                {% if order.shippingRateCents > 0 %}
                    <p>Livraison : {{ order.formattedShippingRate }}</p>
                {% endif %}
                <p><strong>Total : {{ order.formattedTotal }}</strong></p>
            </article>
        </div>
    </section>
{% endblock %}
